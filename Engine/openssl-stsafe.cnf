# openssl-stsafe.cnf
# OpenSSL configuration file for loading the STSAFE-A120 hardware engine.
#
# The engine is backed by the STSELib PKCS#11 provider layer (sal/pkcs11/),
# so all cryptographic operations go through the standard C_SignInit/C_Sign
# PKCS#11 Cryptoki interface.
#
# Usage
# -----
#   export OPENSSL_CONF=/path/to/Engine/openssl-stsafe.cnf
#
#   # Verify the engine loads successfully:
#   openssl engine -v -t stsafe
#
#   # TLS handshake using the STSAFE private key (slot 0) for client auth:
#   openssl s_client \
#       -engine stsafe \
#       -keyform ENGINE -key "0" \
#       -connect <server>:443
#
#   # Run the TLS client example in dynamic-engine mode:
#   ./build/06_TLS_client_dynamic
#   (requires the example to be compiled with -DSTSAFE_USE_DYNAMIC_ENGINE)
#
# Alternative — standalone PKCS#11 module (build/libstsafe_pkcs11.so)
# ----------------------------------------------------------------------
# The PKCS#11 module can be used independently with any PKCS#11-aware
# application (strongSwan, OpenVPN, NSS, pkcs11-tool, etc.).
#
#   # Inspect the token:
#   pkcs11-tool --module build/libstsafe_pkcs11.so --list-objects
#
#   # Sign with OpenSSL 3.x pkcs11-provider (requires openssl-pkcs11-provider):
#   openssl s_client \
#       -provider pkcs11 \
#       -key "pkcs11:token=STSAFE-A120;object=0" \
#       -connect <server>:443
#
#   # Configure libstsafe_pkcs11.so via stse_pkcs11_set_config() before C_Initialize().
#
# Notes
# -----
# * Adjust 'dynamic_path' to the absolute path of libstsafe_engine.so if it
#   is not installed in the OpenSSL engines directory.
# * Adjust I2C_BUS to match the bus exposed on your board's Arduino connector
#   (on STM32MP157-DK2 the Arduino I2C bus is typically i2c-5, so set
#   I2C_BUS = 5).
# * CERT_ZONE is the index into the engine's cert_zone_indices array (always
#   0 for single-zone configuration); the underlying STSAFE zone number is
#   set via the stse_pkcs11_config_t.cert_zone_indices[] array configured
#   inside the engine's init callback.
# * KEY_SLOT corresponds to the STSAFE-A120 private key slot that holds the
#   key pair (PKCS#11 object handle = STSE_PKCS11_PRIVKEY_HANDLE(KEY_SLOT)).
# * 'init = 1' causes ENGINE_init() to be called immediately at load time so
#   that any I2C error is reported during startup rather than at first use.
#
# Known PKCS#11 layer limitations:
#   See Engine/PKCS11_ISSUES.md for a detailed list of compliance issues.
#

# ----- Global OpenSSL init section ----------------------------------------

openssl_conf = openssl_init

[openssl_init]
engines = engine_section

# ----- Engine list --------------------------------------------------------

[engine_section]
stsafe = stsafe_engine_section

# ----- STSAFE engine configuration ----------------------------------------

[stsafe_engine_section]

# Engine identifier (must match STSAFE_ENGINE_ID in stsafe_engine_so.c)
engine_id = stsafe

# Path to the shared library.
# If libstsafe_engine.so is installed in the system ENGINESDIR (returned by
# 'openssl version -e'), you can omit dynamic_path entirely.
# Otherwise set the absolute path, for example:
#   dynamic_path = /opt/stsafe/lib/libstsafe_engine.so
dynamic_path = build/libstsafe_engine.so

# I2C bus number where the STSAFE-A120 is connected.
# Typical value for STM32MP157-DK2 Arduino connector: 5
I2C_BUS = 1

# I2C bus speed in kHz (100 or 400)
I2C_SPEED = 400

# STSAFE data zone index holding the DER leaf certificate (zone 0 by default)
CERT_ZONE = 0

# STSAFE private key slot associated with the leaf certificate
KEY_SLOT = 0

# Initialize the engine immediately at load time (opens /dev/i2c-N via PKCS#11)
init = 1
